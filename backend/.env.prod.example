# ==========================================
# OKK量化交易系统 - 生产环境配置示例
# ==========================================
# 复制此文件为 .env.prod 并填写真实配置

# ==========================================
# OKX API配置
# ==========================================
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here
OKX_SIMULATED=false
OKX_PROXY=

# ==========================================
# 数据库配置
# ==========================================
# 使用1Panel容器名称作为host
# 格式: postgresql+psycopg://用户名:密码@容器名:端口/数据库名
DATABASE_URL=postgresql+psycopg://okk_user:your_db_password@1panel-postgresql-xxxxx:5432/okk_quant

# ==========================================
# Redis配置
# ==========================================
REDIS_HOST=1panel-redis-xxxxx
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ==========================================
# JWT配置
# ==========================================
# 生成强密钥: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_at_least_32_characters_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ==========================================
# CORS配置
# ==========================================
# 允许的前端域名,多个用逗号分隔
ALLOWED_ORIGINS=https://okk.yourdomain.com,https://www.yourdomain.com

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/okk.log

# ==========================================
# 应用配置
# ==========================================
APP_ENV=production
DEBUG=false
